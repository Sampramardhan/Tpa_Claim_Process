SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/api/v1

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/tpa_claims
SPRING_DATASOURCE_USERNAME=tpa_user
SPRING_DATASOURCE_PASSWORD=tpa_password
SPRING_JPA_HIBERNATE_DDL_AUTO=none
SPRING_JPA_DEFAULT_SCHEMA=claim_schema

TPA_API_VERSION=v1
TPA_API_TITLE=TPA Claim Processing API

TPA_JWT_SECRET=replace-with-a-long-random-secret
TPA_JWT_ISSUER=tpa-claim-process
TPA_JWT_EXPIRATION_MINUTES=120
TPA_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

TPA_STATIC_CLIENT_EMAIL=client@tpa.local
TPA_STATIC_CLIENT_PASSWORD=ClientDev@12345
TPA_STATIC_FMG_EMAIL=fmg@tpa.local
TPA_STATIC_FMG_PASSWORD=FmgDev@12345
TPA_STATIC_CARRIER_EMAIL=carrier@tpa.local
TPA_STATIC_CARRIER_PASSWORD=CarrierDev@12345
