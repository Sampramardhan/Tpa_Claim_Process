# Database Credentials for Docker & Spring Boot
POSTGRES_DB=tpa_claims
POSTGRES_USER=tpa_user
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_PORT=5432

# Backend Connection Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/tpa_claims
SPRING_DATASOURCE_USERNAME=tpa_user
SPRING_DATASOURCE_PASSWORD=your_postgres_password_here
SPRING_JPA_DEFAULT_SCHEMA=claim_schema

# Server Context
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/api/v1

VITE_API_BASE_URL=http://localhost:8080/api/v1
VITE_API_TIMEOUT_MS=30000

# Security and JWT
TPA_JWT_SECRET=your_jwt_secret_key_at_least_32_characters_long
TPA_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Static Logins for Officers, Managers, and Carrier Teams
TPA_STATIC_CLIENT_EMAIL=claims.officer@hdfcbank.com
TPA_STATIC_CLIENT_PASSWORD=your_claims_officer_password_here
TPA_STATIC_FMG_EMAIL=review.manager@fmghealth.com
TPA_STATIC_FMG_PASSWORD=your_review_manager_password_here
TPA_STATIC_CARRIER_EMAIL=settlement.team@starhealth.com
TPA_STATIC_CARRIER_PASSWORD=your_carrier_settlement_password_here

# Google AI OCR Configuration (Gemini)
GOOGLE_AI_API_KEY=your_google_ai_gemini_api_key_here
GOOGLE_AI_BASE_URL=https://generativelanguage.googleapis.com
GOOGLE_AI_MODEL=gemini-1.5-flash
